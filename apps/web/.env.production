# Production build config (loaded by `next build`, NOT by local `next dev`).
# On Vercel the gateway service is mounted at routePrefix /_/gateway (see ../../vercel.json),
# so the frontend calls it via this relative prefix (same-origin) instead of localhost:3000.
# Local dev falls back to http://localhost:3000 (this file isn't loaded by `next dev`).
NEXT_PUBLIC_GATEWAY_URL=/_/gateway
